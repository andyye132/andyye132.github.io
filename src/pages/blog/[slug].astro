---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{post.data.title} — Andy Ye</title>
<link rel="icon" type="image/png" href="/favicon.png">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;700&display=swap');
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #f6f1ee; color: #1a1a1a;
    background-image: repeating-linear-gradient(0deg, transparent, transparent 31px, rgba(190,182,174,0.12) 31px, rgba(190,182,174,0.12) 32px);
    background-size: 100% 32px;
  }

  nav {
    position: sticky; top: 0; z-index: 10;
    display: flex; align-items: center; justify-content: flex-end;
    padding: 0 2rem; height: 48px;
    background: rgba(246,241,238,0.65); backdrop-filter: blur(12px);
    font-family: 'JetBrains Mono', monospace;
  }
  nav a { font-size: 0.78rem; color: #4a9a9a; padding: 14px 16px; text-decoration: none; transition: color 0.2s; }
  nav a:hover { color: #2a7a7a; }

  .header {
    max-width: 680px; margin: 0 auto; padding: 3rem 2rem 0;
    text-align: center;
  }
  .header .tags {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem; color: #4a9a9a; text-transform: uppercase;
    letter-spacing: 1.5px; margin-bottom: 1rem;
  }
  .header h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.4rem; font-weight: 900; line-height: 1.2;
    color: #1a1a1a; margin-bottom: 0.8rem;
  }
  .header .desc {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 1.1rem; color: #555; line-height: 1.6;
    font-style: italic; margin-bottom: 1rem;
  }
  .header .byline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; color: #999; letter-spacing: 0.3px;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #d8d0c8;
  }
  .header .banner {
    width: 100%; max-height: 400px; object-fit: cover;
    margin-top: 1.5rem; border: 1px solid #e0d8d0;
  }

  .prose {
    max-width: 680px; margin: 0 auto;
    padding: 2rem 2rem 5rem;
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 1.1rem; line-height: 1.9; color: #2a2a2a;
  }
  .prose p { margin-bottom: 1.2rem; }
  .prose h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.8rem;
    color: #1a1a1a;
  }
  .prose h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.2rem; font-weight: 700; margin: 1.5rem 0 0.6rem;
    color: #1a1a1a;
  }
  .prose a { color: #4a9a9a; text-decoration: underline; text-underline-offset: 3px; }
  .prose blockquote {
    border-left: 3px solid #4a9a9a;
    padding-left: 1.2rem; margin: 1.5rem 0;
    color: #555; font-style: italic;
  }
  .prose ul, .prose ol {
    margin-bottom: 1.2rem; padding-left: 1.5rem;
  }
  .prose li { margin-bottom: 0.4rem; }
  .prose img { max-width: 100%; height: auto; margin: 1.5rem 0; border: 1px solid #e0d8d0; }

  .back-link {
    display: block; max-width: 680px; margin: 0 auto;
    padding: 0 2rem 3rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
  }
  .back-link a { color: #4a9a9a; text-decoration: none; }
  .back-link a:hover { color: #2a7a7a; }

  @media (max-width: 640px) {
    .header h1 { font-size: 1.8rem; }
    .header .desc { font-size: 0.95rem; }
    .prose { font-size: 1rem; padding: 1.5rem 1rem 4rem; }
    .header { padding: 2rem 1rem 0; }
  }
</style>
</head>
<body>
<nav>
  <a href="/">home</a>
  <a href="/Pages/Materials/Resume_Feb_7.pdf" target="_blank">cv</a>
  <a href="/blog-archive" style="color:#2a2a2a;">blog</a>
  <a href="/creative">portfolio</a>
</nav>

<div class="header">
  <div class="tags">{post.data.tags.join(' · ')}</div>
  <h1>{post.data.title}</h1>
  <div class="desc">{post.data.description}</div>
  <div class="byline">By Andy Ye · {dateStr}</div>
  {post.data.image && <img src={post.data.image} alt={post.data.title} class="banner" />}
</div>

<div class="prose"><Content /></div>

<div class="back-link"><a href="/blog-archive">&larr; back to on the pursuit for one good idea</a></div>
</body>
</html>
