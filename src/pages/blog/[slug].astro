---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{post.data.title} — Andy Ye</title>
<link rel="icon" type="image/png" href="/favicon.png">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #fbfaf6; color: #1d1d1b; font-family: Georgia, 'Times New Roman', serif; font-size: 16.5px; line-height: 1.75; }
  ::selection { background: #1c3aa9; color: #fff; }
  a { color: #1c3aa9; }

  .masthead { text-align: center; padding: 2.6rem 1rem 1.3rem; }
  .masthead h1 { font-size: 2.5rem; font-weight: 700; color: #a09b92; letter-spacing: .02em; }
  .masthead h1 a { color: inherit; text-decoration: none; }

  nav.bar { border-top: 3px solid #ccc8c0; border-bottom: 3px solid #ccc8c0; background: #fffefb; }
  nav.bar ul { list-style: none; display: flex; justify-content: space-around; flex-wrap: wrap; max-width: 780px; margin: 0 auto; }
  nav.bar a { display: block; padding: .5rem 1.6rem; color: #1c3aa9; font-size: 1.05rem; text-decoration: none; }
  nav.bar a:hover { text-decoration: underline; }
  nav.bar .here { font-weight: 700; }

  .header { max-width: 680px; margin: 0 auto; padding: 2.6rem 1.4rem 0; text-align: center; }
  .header .tags { font-family: 'Courier New', Courier, monospace; font-size: .78rem; color: #a19b90;
    letter-spacing: .12em; text-transform: lowercase; margin-bottom: .8rem; }
  .header h2 { font-size: 2rem; font-weight: 700; line-height: 1.25; margin-bottom: .7rem; }
  .header .desc { font-style: italic; color: #6b665d; font-size: 1.08rem; margin-bottom: .9rem; }
  .header .byline { font-family: 'Courier New', Courier, monospace; font-size: .8rem; color: #a19b90;
    padding-bottom: 1.4rem; border-bottom: 1px solid #ddd8cf; }
  .header .banner { width: 100%; max-height: 400px; object-fit: cover; margin-top: 1.5rem;
    background: #fff; border: 1px solid #ccc8c0; padding: 4px; }

  .prose { max-width: 680px; margin: 0 auto; padding: 2rem 1.4rem 4rem; font-size: 1.06rem; line-height: 1.9; color: #26251f; }
  .prose p { margin-bottom: 1.2rem; }
  .prose h2 { font-size: 1.4rem; font-weight: 700; margin: 2rem 0 .8rem; }
  .prose h3 { font-size: 1.15rem; font-weight: 700; margin: 1.5rem 0 .6rem; }
  .prose a { color: #1c3aa9; }
  .prose blockquote { border-left: 3px solid #ccc8c0; padding-left: 1.2rem; margin: 1.5rem 0; color: #6b665d; font-style: italic; }
  .prose ul, .prose ol { margin-bottom: 1.2rem; padding-left: 1.5rem; }
  .prose li { margin-bottom: .4rem; }
  .prose img { max-width: 100%; height: auto; margin: 1.5rem 0; background: #fff; border: 1px solid #ccc8c0; padding: 4px; }

  .back-link { max-width: 680px; margin: 0 auto; padding: 0 1.4rem 3rem; font-size: .92rem; }

  footer { text-align: center; padding: 0 1rem 3rem; font-family: 'Courier New', Courier, monospace;
    color: #b5afa4; font-size: .8rem; }

  @media (max-width: 640px) {
    .masthead h1 { font-size: 1.9rem; }
    nav.bar a { padding: .45rem .9rem; font-size: .95rem; }
    .header h2 { font-size: 1.5rem; }
  }
</style>
</head>
<body>

<header class="masthead"><h1><a href="/">Andy Ye</a></h1></header>
<nav class="bar">
  <ul>
    <li><a href="/">home</a></li>
    <li><a class="here" href="/blog-archive">blog</a></li>
    <li><a href="/cs">projects/research</a></li>
    <li><a href="/creative">creative</a></li>
    <li><a href="/cv">cv</a></li>
  </ul>
</nav>

<div class="header">
  <div class="tags">{post.data.tags.join(' · ')}</div>
  <h2>{post.data.title}</h2>
  <div class="desc">{post.data.description}</div>
  <div class="byline">by andy ye · {dateStr.toLowerCase()}</div>
  {post.data.image && <img src={post.data.image} alt={post.data.title} class="banner" />}
</div>

<div class="prose"><Content /></div>

<div class="back-link"><a href="/blog-archive">&larr; back to on the pursuit for one good idea</a></div>

<footer>© 2026 andy ye · seattle, wa</footer>
</body>
</html>
