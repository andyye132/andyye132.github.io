---
// Whole-island voxel map. Overview → hover a zone (glowing border + label) →
// click to fly in → hover/click a building → zoom + content panel. Esc / back steps out.
---
<!doctype html>
<html>
<head><meta charset="utf-8"><title>voxel map</title>
<style is:global>
  html,body{margin:0;height:100%;background:#0e1014;overflow:hidden;font:12px 'JetBrains Mono',monospace}
  #hud{position:fixed;top:8px;left:8px;color:#9fb;white-space:pre;z-index:9;text-shadow:0 1px 2px #000}
  #hint{position:fixed;top:8px;right:10px;color:#789;z-index:9}
  /* film-grain overlay (unseen / crt3d style) */
  #grain{position:fixed;top:-50%;left:-50%;width:200%;height:200%;z-index:7;pointer-events:none;opacity:0.10;
    mix-blend-mode:overlay;background-repeat:repeat;will-change:transform;animation:grain .7s steps(3) infinite}
  @keyframes grain{0%{transform:translate(0,0)}33%{transform:translate(-4%,3%)}66%{transform:translate(3%,-3%)}100%{transform:translate(-2%,4%)}}
  /* floating zone labels (crisp DOM text projected to screen) — large, glowing section headers */
  .zone-label{position:fixed;transform:translate(-50%,-50%);font-weight:800;font-size:46px;letter-spacing:.06em;
    pointer-events:none;z-index:8;white-space:nowrap;opacity:0;transition:opacity .2s,transform .2s;
    text-shadow:0 2px 12px rgba(0,0,0,.72),0 0 5px rgba(0,0,0,.5);}
  /* building labels — styled like the section headers: colored by zone accent + a soft glow */
  .bldg-label{position:fixed;transform:translate(-50%,-50%);font-weight:700;font-size:30px;letter-spacing:.03em;
    color:#fff;pointer-events:none;z-index:8;white-space:nowrap;opacity:0;transition:opacity .15s,transform .15s;
    text-shadow:0 2px 8px rgba(0,0,0,.8),0 0 4px rgba(0,0,0,.6);}
  /* back button (drill-down only — bottom center) */
  #back{position:fixed;bottom:26px;left:50%;transform:translateX(-50%);z-index:12;background:rgba(10,14,20,.6);
    border:1px solid #2a3038;color:#cde;padding:6px 14px;border-radius:7px;cursor:pointer;font:13px 'JetBrains Mono',monospace;
    opacity:0;pointer-events:none;transition:opacity .2s;}
  #back.show{opacity:1;pointer-events:auto;}
  /* raft "back" label — small CRT-terminal green, floats over the log raft */
  .raft-label{position:fixed;transform:translate(-50%,-50%);font-weight:700;font-size:19px;letter-spacing:.14em;
    color:#82ffba;pointer-events:none;z-index:8;white-space:nowrap;opacity:0;transition:opacity .2s,transform .2s;
    text-shadow:0 2px 8px rgba(0,0,0,.8), 0 0 10px rgba(91,255,158,.9), 0 0 24px rgba(91,255,158,.5);}
  /* fade back to the monitor (matches crt3d's room black) */
  #fade{position:fixed;inset:0;z-index:40;background:#0a0810;opacity:0;pointer-events:none;transition:opacity .5s ease;}
  #fade.on{opacity:1;pointer-events:auto;}
  /* ── content = a FILE FOLDER that opens: the front cover SLIDES DOWN to reveal the page inside.
        Folder color is per-zone (--folder, set in JS). Pure CSS (no WebGL). Near-full-screen. ── */
  #panel{position:fixed;inset:0;margin:auto;width:min(72vw,1200px);height:82vh;z-index:20;
    visibility:hidden;pointer-events:none;--folder:#e7d6a6;transform:translateY(0);transition:transform .6s cubic-bezier(.45,.05,.3,1);}
  #panel.active{visibility:visible;}
  #panel.open{pointer-events:auto;}
  #panel.exit{transform:translateY(122vh);}                 /* close = the whole folder slides down off-screen */
  /* the open folder (back) holding the document (the page) */
  #panel .doc{position:absolute;inset:0;display:flex;flex-direction:column;overflow:hidden;border-radius:5px 5px 12px 12px;
    background:var(--folder);box-shadow:0 46px 130px rgba(0,0,0,.62),inset 0 0 0 2px color-mix(in srgb,var(--folder) 66%,#4a3a12);}
  #panel .phead{display:flex;align-items:center;justify-content:space-between;padding:12px 22px;
    background:color-mix(in srgb,var(--folder) 84%,#6a531f);border-bottom:1px solid color-mix(in srgb,var(--folder) 55%,#4a3a12);}
  #panel .ptitle{color:#3a2c10;font-weight:700;font-size:19px;letter-spacing:.03em;}
  #panel .pclose{cursor:pointer;background:color-mix(in srgb,var(--folder) 80%,#fff);border:1px solid color-mix(in srgb,var(--folder) 55%,#4a3a12);
    color:#3a2c10;border-radius:6px;padding:6px 13px;font:13px 'JetBrains Mono',monospace;}
  #panel .pclose:hover{background:#fff;}
  #panel .pbody{flex:1;overflow:auto;position:relative;margin:10px;border-radius:6px;background:#0b0e15;box-shadow:0 3px 16px rgba(0,0,0,.4);}
  #panel .pbody.pad{padding:26px;line-height:1.66;color:#e6ecf4;}
  #panel .pbody .tags{color:var(--accent,#a8c7fa);margin-top:12px;font-size:13px;}
  #panel .pbody iframe{display:block;width:100%;height:100%;border:0;border-radius:6px;background:#fff;opacity:0;transition:opacity .4s ease;}
  #panel .pbody.loaded iframe{opacity:1;}
  /* front cover — folder-colored sheet + tab; slides down smoothly to reveal the page (top→bottom) */
  #panel .cover{position:absolute;inset:0;z-index:3;border-radius:5px 5px 12px 12px;
    background:linear-gradient(158deg,color-mix(in srgb,var(--folder) 78%,#fff) 0%,var(--folder) 55%,color-mix(in srgb,var(--folder) 82%,#000) 100%);
    box-shadow:inset 0 0 0 2px color-mix(in srgb,var(--folder) 66%,#4a3a12),inset 0 3px 0 color-mix(in srgb,var(--folder) 55%,#fff),0 46px 130px rgba(0,0,0,.62);
    transform:translateY(0);transition:transform .9s cubic-bezier(.4,.04,.2,1);}
  #panel.open .cover{transform:translateY(103%);pointer-events:none;}
  #panel .cover::before{content:'';position:absolute;top:-34px;left:8%;width:26%;height:36px;border-radius:10px 10px 0 0;
    background:linear-gradient(158deg,color-mix(in srgb,var(--folder) 78%,#fff),var(--folder));
    box-shadow:inset 0 0 0 2px color-mix(in srgb,var(--folder) 66%,#4a3a12),inset 0 3px 0 color-mix(in srgb,var(--folder) 55%,#fff);}
  #panel .cover::after{content:'';position:absolute;left:7%;right:7%;bottom:15%;height:2px;background:#4a3a1226;}
  @media (prefers-reduced-motion:reduce){#panel .cover,#panel .doc{transition:none;}}
</style>
</head>
<body>
<div id="hud">building map…</div>
<div id="hint">hover a zone · click to enter · click a building</div>
<div id="grain"></div>
<button id="back">‹ back</button>
<div id="fade"></div>
<div id="panel">
  <div class="doc"><div class="phead"><span class="ptitle"></span><button class="pclose">× close</button></div><div class="pbody"></div></div>
  <div class="cover"></div>
</div>
<script>
import * as THREE from 'three';
import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
import { ShaderPass } from 'three/addons/postprocessing/ShaderPass.js';
import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';
import { FullScreenQuad } from 'three/addons/postprocessing/Pass.js';
import { makeVoxels } from '../voxrender.js';
import { buildMap, GRID, TILE, LAYOUT, ZONES, RAFT, zoneAt, depthAt } from '../voxmap.js';
import { buildVox } from '../voxbuildings.js';

// short display names + per-building top height (for floating labels)
const BNAMES = { art:'art', blog1:'blog', cards:'games', blog4:'archive', project1:'misc', project2:'game development',
  research1:'robotics', research2:'ubiquitous computing', resumeBuilding:'resume', transcript:'transcript', infobuilding:'about' };
const HEIGHTS = {}, BDIMS = {};   // per-building top height (labels) + footprint bbox (hover borders)
for (const [key] of LAYOUT){ let h=0, mnx=1e9,mxx=-1e9,mnz=1e9,mxz=-1e9;
  for (const v of buildVox(key)){ if (v.y>h) h=v.y;
    if (v.y>=0){ if(v.x<mnx)mnx=v.x; if(v.x>mxx)mxx=v.x; if(v.z<mnz)mnz=v.z; if(v.z>mxz)mxz=v.z; } }
  HEIGHTS[key]=h; BDIMS[key]={ w:mxx-mnx+1, d:mxz-mnz+1 }; }

const vox = buildMap();

const renderer = new THREE.WebGLRenderer({ antialias:false, powerPreference:'high-performance' });   // backbuffer only receives fullscreen quads — geometry AA comes from islandRT's MSAA
renderer.setPixelRatio(1); renderer.setSize(innerWidth, innerHeight);
renderer.shadowMap.enabled = true; renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.NeutralToneMapping; renderer.toneMappingExposure = 1.02;   // lower; the grade warms it
renderer.outputColorSpace = THREE.SRGBColorSpace;
document.body.appendChild(renderer.domElement);

const scene = new THREE.Scene(); scene.background = new THREE.Color('#0b0a12');
scene.fog = new THREE.Fog(0x14121c, 360, 580);   // dark moody haze fogs the far sea; camera sits ~280 back

// warm IBL env (golden-hour) — drives the island + water shading toward the crt3d look
function envTex(){ const c=document.createElement('canvas'); c.width=16; c.height=256; const x=c.getContext('2d');
  const g=x.createLinearGradient(0,0,0,256); g.addColorStop(0,'#cdd2e0'); g.addColorStop(.5,'#e8cdb2'); g.addColorStop(.64,'#caa78c'); g.addColorStop(1,'#2a2024');
  x.fillStyle=g; x.fillRect(0,0,16,256);
  const lobe=x.createRadialGradient(8,96,0,8,96,9); lobe.addColorStop(0,'rgba(255,224,176,0.9)'); lobe.addColorStop(1,'rgba(0,0,0,0)');
  x.globalCompositeOperation='lighter'; x.fillStyle=lobe; x.fillRect(0,60,16,72); x.globalCompositeOperation='source-over';
  const t=new THREE.CanvasTexture(c); t.mapping=THREE.EquirectangularReflectionMapping; return t; }
const pmrem = new THREE.PMREMGenerator(renderer); scene.environment = pmrem.fromEquirectangular(envTex()).texture; scene.environmentIntensity = 0.92;

const sun = new THREE.DirectionalLight(0xffe6c0, 2.6); sun.position.set(70, 120, 48); sun.castShadow = true;
sun.shadow.mapSize.set(2048,2048); sun.shadow.radius = 4; sun.shadow.bias = -0.0004; sun.shadow.normalBias = 0.6;
const sc = sun.shadow.camera; sc.left=-78; sc.right=78; sc.top=78; sc.bottom=-78; sc.near=1; sc.far=320; scene.add(sun);
const hemi = new THREE.HemisphereLight(0xffe9d0, 0x4a3a30, 0.55); scene.add(hemi);
const amb = new THREE.AmbientLight(0xc9d6e4, 0.13); scene.add(amb);   // soft floor so shaded building sides never crush to black

// gradient backdrop sphere (warm dusk sky + glow toward the sun) — replaces the flat blue bg
const SUN_DIR = sun.position.clone().normalize();
const backdrop = new THREE.Mesh(new THREE.SphereGeometry(600, 32, 16), new THREE.ShaderMaterial({
  side: THREE.BackSide, depthWrite: false, fog: false,
  uniforms: { uTop:{value:new THREE.Vector3(0.09,0.10,0.16)}, uMid:{value:new THREE.Vector3(0.055,0.055,0.095)},
    uBot:{value:new THREE.Vector3(0.02,0.022,0.038)}, uGlowCol:{value:new THREE.Vector3(0.55,0.42,0.5)},
    uGlowDir:{value:SUN_DIR.clone()}, uGlowInt:{value:0.35} },   // dark moody sky → water reflects DARK = glossy black liquid
  vertexShader:`varying vec3 vW; void main(){ vec4 wp=modelMatrix*vec4(position,1.0); vW=wp.xyz; gl_Position=projectionMatrix*viewMatrix*wp; }`,
  fragmentShader:`varying vec3 vW; uniform vec3 uTop,uMid,uBot,uGlowCol,uGlowDir; uniform float uGlowInt;
    void main(){ vec3 dir=normalize(vW-cameraPosition); float h=clamp(dir.y*0.5+0.5,0.0,1.0);
      vec3 col=mix(uBot,uMid,smoothstep(0.32,0.56,h)); col=mix(col,uTop,smoothstep(0.56,0.95,h));
      float gd=max(dot(dir,normalize(uGlowDir)),0.0); col+=uGlowCol*pow(smoothstep(0.5,1.0,gd),1.4)*uGlowInt;
      gl_FragColor=vec4(col,1.0); }`}));
backdrop.renderOrder = -10; scene.add(backdrop);

// the sun is INVISIBLE (no disc) — SUN_POS is just the screen-space marker that positions the god-ray shafts
const SUN_POS = SUN_DIR.clone().multiplyScalar(180);

const SPAN = GRID * TILE, HALF = SPAN/2;
const { root, bounds, counts, warmMat } = makeVoxels(vox);
root.position.set(-HALF, 0, -HALF);
const grp = new THREE.Group(); grp.add(root); scene.add(grp);

// ── water: SCREEN-SPACE planar reflection. THREE.Water's mirror math is perspective-only and
//    BREAKS under our orthographic camera. Instead we render the island + sky to textures and
//    reflect them about the waterline in a fullscreen pass — EXACT for a fixed ortho camera
//    (a point at +H projects to v_surf−k·H, its mirror at −H to 2·v_surf−v). This is index.html's
//    technique, ported to consume our 3D render. Set up after the camera exists (below). ──
const WATER_Y = -1.7;

// ── zone geometry: rect (bbox of member footprints + pad) + centroid + camera span ──
const wx = gx => gx*TILE - HALF, wz = gy => gy*TILE - HALF;
const ZINFO = {};
for (const z in ZONES){
  const ms = ZONES[z].members.map(k => LAYOUT.find(l => l[0]===k)).filter(Boolean);
  let x1=1e9,x2=-1e9,y1=1e9,y2=-1e9,cx=0,cy=0;
  for (const [,gx,gy] of ms){ x1=Math.min(x1,gx); y1=Math.min(y1,gy); x2=Math.max(x2,gx+2); y2=Math.max(y2,gy+2); cx+=gx+1; cy+=gy+1; }
  cx/=ms.length; cy/=ms.length; const pad=1.3;
  const rx1=wx(x1-pad), rx2=wx(x2+pad), rz1=wz(y1-pad), rz2=wz(y2+pad);
  ZINFO[z] = { rx1, rx2, rz1, rz2, cx:wx(cx), cz:wz(cy), color:ZONES[z].color, label:ZONES[z].label,
    span: Math.max(rx2-rx1, rz2-rz1) * 0.62 };
}

// ── glowing raised border (4 thin unlit walls), reused per hovered zone ──
const borderMat = new THREE.MeshBasicMaterial({ color:0xffffff, transparent:true, opacity:0.55, depthWrite:true });   // writes depth so the water compositor keeps it ABOVE water (+ it reflects)
const borderGrp = new THREE.Group(); borderGrp.visible = false; scene.add(borderGrp);
const walls = []; for (let i=0;i<4;i++){ const w=new THREE.Mesh(new THREE.BoxGeometry(1,1,1), borderMat); borderGrp.add(w); walls.push(w); }
function setBorder(z){ if (!z){ borderGrp.visible=false; return; }
  const r=ZINFO[z]; borderGrp.visible=true; borderMat.color.set(r.color);
  const h=3.6, y=h/2, th=0.9, W=r.rx2-r.rx1, D=r.rz2-r.rz1, mx=(r.rx1+r.rx2)/2, mz=(r.rz1+r.rz2)/2;
  walls[0].scale.set(W,h,th); walls[0].position.set(mx,y,r.rz1);
  walls[1].scale.set(W,h,th); walls[1].position.set(mx,y,r.rz2);
  walls[2].scale.set(th,h,D); walls[2].position.set(r.rx1,y,mz);
  walls[3].scale.set(th,h,D); walls[3].position.set(r.rx2,y,mz); }

// ── building hover highlight: a glowing raised BORDER sized to each building's footprint
//    (the old fixed-size ring vanished under big buildings) ──
const ringMat = new THREE.MeshBasicMaterial({ color:0xffffff, transparent:true, opacity:0.7, depthWrite:true });   // above water + reflected
const bldgBorderGrp = new THREE.Group(); bldgBorderGrp.visible = false; scene.add(bldgBorderGrp);
const bwalls = []; for (let i=0;i<4;i++){ const w=new THREE.Mesh(new THREE.BoxGeometry(1,1,1), ringMat); bldgBorderGrp.add(w); bwalls.push(w); }
function setRing(key){ if (!key){ bldgBorderGrp.visible=false; return; } const e=LAYOUT.find(l=>l[0]===key); if(!e)return;
  const dim = BDIMS[key]||{w:12,d:12}, pad=1.8, h=2.6, th=0.8;
  const W=dim.w+pad*2, D=dim.d+pad*2, mx=wx(e[1]+1), mz=wz(e[2]+1), y=h/2;
  bwalls[0].scale.set(W,h,th); bwalls[0].position.set(mx,y,mz-D/2);
  bwalls[1].scale.set(W,h,th); bwalls[1].position.set(mx,y,mz+D/2);
  bwalls[2].scale.set(th,h,D); bwalls[2].position.set(mx-W/2,y,mz);
  bwalls[3].scale.set(th,h,D); bwalls[3].position.set(mx+W/2,y,mz);
  bldgBorderGrp.visible=true;
  // SHINE: push the accent past 1.0 so bloom halos it — pale accents (creative gold) were invisible on sand
  ringMat.color.set(ZONES[activeZone]?.color||'#fff').lerp(new THREE.Color('#ffffff'), 0.25).multiplyScalar(1.6); }

// ── camera (fixed dimetric, eased tween, render-on-demand) ──
const DIR = new THREE.Vector3(1, 0.85, 1).normalize();
// camera screen axes (fixed) → so the sun can be placed by SCREEN intent (top) and shadows fall away from it
const _camF = DIR.clone().negate();
const camR = new THREE.Vector3().crossVectors(_camF, new THREE.Vector3(0,1,0)).normalize();   // screen-right
const camU = new THREE.Vector3().crossVectors(camR, _camF).normalize();                        // screen-up
const skyBack  = new THREE.Vector3(camU.x, 0, camU.z).normalize();   // ground dir that projects "up-screen" (light from here → shadows fall down-screen, toward viewer)
const skyRight = new THREE.Vector3(camR.x, 0, camR.z).normalize();   // ground dir that projects "right-screen" (the dawn→dusk arc)
const OVERVIEW = { t: new THREE.Vector3(0, 2, 0), span: HALF * 1.16 };
const cam = new THREE.OrthographicCamera(-1, 1, 1, -1, -400, 900);
const cur = { t: OVERVIEW.t.clone(), span: OVERVIEW.span };
let anim = null, need = true, firstRendered = false, _rtDirty = true, _uiDirty = true;
const ease = k => k < 0.5 ? 4*k*k*k : 1 - Math.pow(-2*k+2, 3)/2;
function tweenTo(t, span){ anim = { fromT: cur.t.clone(), toT: t.clone(), fromSpan: cur.span, toSpan: span, t0: performance.now(), dur: 560 }; need = true; }
function applyCam(){ const a = innerWidth/innerHeight;
  cam.position.copy(DIR).multiplyScalar(280).add(cur.t); cam.lookAt(cur.t);
  cam.left=-cur.span*a; cam.right=cur.span*a; cam.top=cur.span; cam.bottom=-cur.span; cam.updateProjectionMatrix(); }
applyCam();

/* ===== post-processing: god rays → bloom → dusty-rose grade (ported from crt3d) ===== */
// INVISIBLE-SOURCE god rays: radial-scatter an analytic sky-source, with the island alpha as a HARD
// black occluder → shafts break around the island and fall on the water. coreMask kills the disc.
// PERF: the 28-sample march runs in a HALF-RES prepass (shafts are soft/low-frequency, so a bilinear
// upsample is visually identical at ~1/4 the marching cost); the composer pass is then a single tap.
const rayGenMat = new THREE.ShaderMaterial({
  uniforms:{ tIsland:{value:null}, lightPos:{value:new THREE.Vector2(0.5,0.8)},
    density:{value:1.05}, weight:{value:0.5}, decay:{value:0.98}, exposure:{value:0.11},   // rays reach further down the frame; subtle but visible shafts
    uSunSize:{value:0.42}, uAspect:{value:1.0}, uTime:{value:0.0} },
  vertexShader:`varying vec2 vUv; void main(){ vUv=uv; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0); }`,
  fragmentShader:`#define SAMPLES 28
    uniform sampler2D tIsland; uniform vec2 lightPos;
    uniform float density,weight,decay,exposure,uSunSize,uAspect,uTime; varying vec2 vUv;
    float ign(vec2 p){ return fract(52.9829189*fract(dot(p,vec2(0.06711056,0.00583715)))); }
    void main(){
      vec2 delta=(vUv-lightPos)*(density/float(SAMPLES));       // UV space (NOT aspect-corrected → straight shafts)
      vec2 coord=vUv - delta*ign(gl_FragCoord.xy);              // dithered start → stable, no banding as the sun moves
      float illum=1.0, ray=0.0;
      for(int i=0;i<SAMPLES;i++){ coord-=delta;
        vec2 dd=coord-lightPos; dd.x*=uAspect;
        float src=smoothstep(uSunSize,0.0,length(dd));          // bright sky toward the (invisible) sun
        float occ=1.0-step(0.5,texture2D(tIsland,coord).a);     // island silhouette = hard occluder → gaps
        ray+=src*occ*illum*weight; illum*=decay; }
      ray*=exposure;
      // radial STREAKS → distinct golden-hour light shafts fanning from the sun (slowly drifting)
      vec2 sd=vUv-lightPos; sd.x*=uAspect; float ang=atan(sd.y, sd.x);
      float streak=0.25 + 0.75*(0.5+0.5*sin(ang*13.0+uTime*0.12))*(0.55+0.45*sin(ang*6.0-uTime*0.08));
      ray*=streak;
      float edge=smoothstep(1.7,0.15,length(vUv-0.5));         // soft frame falloff (no dark core mask → the source glow shows)
      gl_FragColor=vec4(ray*edge,0.0,0.0,1.0); }`
});
const rayQuad = new FullScreenQuad(rayGenMat);
let rayRT;
function makeRayRT(w,h){ rayRT?.dispose();
  rayRT = new THREE.WebGLRenderTarget(Math.max(1,Math.floor(w*0.5)), Math.max(1,Math.floor(h*0.5)),
    { type:THREE.HalfFloatType, minFilter:THREE.LinearFilter, magFilter:THREE.LinearFilter, depthBuffer:false }); }
makeRayRT(innerWidth, innerHeight);
const GodRays = {
  uniforms:{ tDiffuse:{value:null}, tRay:{value:null}, uColor:{value:new THREE.Vector3(1.0,0.94,0.86)}, uLightOn:{value:1.0} },
  vertexShader:`varying vec2 vUv; void main(){ vUv=uv; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0); }`,
  fragmentShader:`uniform sampler2D tDiffuse, tRay; uniform vec3 uColor; uniform float uLightOn; varying vec2 vUv;
    void main(){ vec3 base=texture2D(tDiffuse,vUv).rgb;
      gl_FragColor=vec4(base + uColor*texture2D(tRay,vUv).r*uLightOn, 1.0); }`
};
const godrays = new ShaderPass(GodRays);
const Grade = {
  uniforms:{ tDiffuse:{value:null}, time:{value:0}, uExposure:{value:1.0}, uContrast:{value:1.08},
    uTintShadow:{value:0.12}, uTintMid:{value:0.14}, uTintHigh:{value:0.15}, uDesatHi:{value:0.08},
    uLift:{value:0.015}, uVignette:{value:0.34}, uGrain:{value:0.018} },
  vertexShader:`varying vec2 vUv; void main(){ vUv=uv; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0); }`,
  fragmentShader:`uniform sampler2D tDiffuse; uniform float time,uExposure,uContrast,uTintShadow,uTintMid,uTintHigh,uDesatHi,uLift,uVignette,uGrain; varying vec2 vUv;
    const vec3 PAL_SHADOW=vec3(0.044,0.056,0.090); const vec3 PAL_MID=vec3(0.780,0.790,0.895); const vec3 PAL_HIGH=vec3(0.892,0.922,0.968);
    float luma(vec3 c){ return dot(c,vec3(0.2126,0.7152,0.0722)); }
