  return { top:C(a._top,b._top), mid:C(a._mid,b._mid), bot:C(a._bot,b._bot), glow:C(a._glow,b._glow), glowInt:N(a.glowInt,b.glowInt),
    fog:C(a._fog,b._fog), fogN:N(a.fogN,b.fogN), fogF:N(a.fogF,b.fogF), deep:C(a._deep,b._deep), shallow:C(a._shallow,b._shallow),
    sun:C(a._sun,b._sun), sunI:N(a.sunI,b.sunI), envI:N(a.envI,b.envI), expo:N(a.expo,b.expo), moon:N(a.moon,b.moon),
    refl:N(a.refl,b.refl), bloom:N(a.bloom,b.bloom), phase:N(a.phase,b.phase), gray:N(a.gray,b.gray) };
}
function applyTime(hr){
  const P=lerpTime(hr), bu=backdrop.material.uniforms;
  bu.uTop.value.set(P.top.r,P.top.g,P.top.b); bu.uMid.value.set(P.mid.r,P.mid.g,P.mid.b); bu.uBot.value.set(P.bot.r,P.bot.g,P.bot.b);
  bu.uGlowCol.value.set(P.glow.r,P.glow.g,P.glow.b); bu.uGlowInt.value=P.glowInt;
  scene.fog.color.copy(P.fog); scene.fog.near=P.fogN; scene.fog.far=P.fogF;
  scene.background.copy(P.bot).multiplyScalar(0.55);
  // sun/moon arc across the sky by the hour
  // sun placed by SCREEN intent: high up (+y), toward screen-up on the ground (skyBack) so shadows fall
  // DOWN-screen away from it, and swung left↔right (skyRight) by the hour. Glow & shadows now agree.
  const az = (P.phase-0.5)*Math.PI*0.92, side = Math.sin(az) * 0.85;   // dawn = left, noon = top, dusk = right
  SUN_DIR.copy(skyBack).multiplyScalar(0.5).addScaledVector(skyRight, side).setY(0.92).normalize();
  SUN_POS.copy(SUN_DIR).multiplyScalar(180);
  sun.position.copy(SUN_DIR).multiplyScalar(120); sun.color.copy(P.sun); sun.intensity=P.sunI; sun.target.updateMatrixWorld();
  hemi.color.copy(P.sun); hemi.intensity=_mix(0.85,0.6,P.moon);
  scene.environmentIntensity=P.envI; renderer.toneMappingExposure=P.expo;
  // warm night lights (lamp globes + lit windows): off in daylight, glowing from dusk through dawn
  const dayness = THREE.MathUtils.smoothstep(hr,5.5,8.0) * (1.0 - THREE.MathUtils.smoothstep(hr,17.0,19.5));
  if (warmMat) warmMat.emissiveIntensity = 0.10 + (1.0-dayness)*2.15;
  waterPass.uniforms.uDeep.value.copy(P.deep); waterPass.uniforms.uShallow.value.copy(P.shallow);
  waterPass.uniforms.uSunCol.value.set(P.sun.r,P.sun.g,P.sun.b); waterPass.uniforms.uReflAmt.value=P.refl;
  godrays.uniforms.uColor.value.set(P.sun.r,P.sun.g,P.sun.b);   // shafts share the sun/moon color (warm-white ↔ blue-white)
  rayGenMat.uniforms.exposure.value = P.gray;                   // dampened at dusk so the shafts don't wash the whole sea warm
  bu.uGlowDir.value.copy(SUN_DIR); bloom.strength=P.bloom;
  renderer.shadowMap.needsUpdate=true; _rtDirty=true;   // refresh the frozen shadow + island RT for the new light
}
const _tq = new URLSearchParams(location.search).get('t');
function nowHour(){ if(_tq==='day')return 12; if(_tq==='night')return 0; if(_tq==='dawn')return 6.5; if(_tq==='dusk')return 18.5;
  const n=parseFloat(_tq); if(!isNaN(n)) return n;   // ?t=15.7 → exact hour (dev)
  const d=new Date(); return d.getHours()+d.getMinutes()/60; }
applyTime(nowHour());
setInterval(() => applyTime(nowHour()), 60000);   // keep synced to the viewer's clock

const _sp = new THREE.Vector3();
function updateGodrays(){
  _sp.copy(SUN_POS).project(cam); const ux=_sp.x*0.5+0.5, uy=_sp.y*0.5+0.5;
  rayGenMat.uniforms.lightPos.value.set(ux, uy);
  rayGenMat.uniforms.tIsland.value = islandRT.texture;
  rayGenMat.uniforms.uAspect.value = innerWidth/innerHeight;
  const inF = _sp.z<1.0 ? 1.0 : 0.0;   // keep rays even when the (invisible) sun sits just past the frame edge
  const onX = THREE.MathUtils.smoothstep(ux,-0.7,-0.1)*(1.0-THREE.MathUtils.smoothstep(ux,1.1,1.7));
  const onY = THREE.MathUtils.smoothstep(uy,-0.7,-0.1)*(1.0-THREE.MathUtils.smoothstep(uy,1.1,1.7));
  godrays.uniforms.uLightOn.value = inF*onX*onY;
  godrays.uniforms.tRay.value = rayRT.texture;
}
function renderRays(){   // half-res shaft prepass — skipped when the light is off-frame or rays are off (floor quality tier)
  if (!godrays.enabled || godrays.uniforms.uLightOn.value <= 0.001) return;
  renderer.setRenderTarget(rayRT); rayQuad.render(renderer); renderer.setRenderTarget(null);
}

// ── floating zone labels (DOM) ──
// colored halo built from a label's own accent → the glow matches the section color
const glowRGBA = (hex, a) => { const n = parseInt(hex.slice(1),16); return `rgba(${(n>>16)&255},${(n>>8)&255},${n&255},${a})`; };
const labelEls = {};
for (const z in ZINFO){ const el=document.createElement('div'); el.className='zone-label'; el.textContent=ZINFO[z].label;
  const col=ZINFO[z].color; el.style.color=col;
  el.style.textShadow=`0 2px 10px rgba(0,0,0,.72), 0 0 14px ${glowRGBA(col,.95)}, 0 0 30px ${glowRGBA(col,.6)}, 0 0 54px ${glowRGBA(col,.38)}`;
  document.body.appendChild(el); labelEls[z]=el; }
// building name → its zone's accent color, so building labels read like the section header
const BCOL = {}; for (const z in ZONES) for (const k of ZONES[z].members) BCOL[k]=ZONES[z].color;
const bldgEls = {};
for (const [key] of LAYOUT){ const el=document.createElement('div'); el.className='bldg-label'; el.textContent=BNAMES[key]||key;
  const col=BCOL[key]||'#e4ecf6'; el.style.color=col;
  el.style.textShadow=`0 2px 8px rgba(0,0,0,.82), 0 0 11px ${glowRGBA(col,.85)}, 0 0 24px ${glowRGBA(col,.5)}`;
  document.body.appendChild(el); bldgEls[key]=el; }
const raftEl = document.createElement('div'); raftEl.className='raft-label'; raftEl.textContent='back';
document.body.appendChild(raftEl);
const _v = new THREE.Vector3();
const toScreen = el => { el.style.left=((_v.x*0.5+0.5)*innerWidth)+'px';
  el.style.top=Math.max(52, (-_v.y*0.5+0.5)*innerHeight)+'px'; };   // clamp below the hud/back button (tall models: the robot)
function updateLabels(){
  // zone labels — only in overview
  const zShow = viewState==='overview';
  for (const z in ZINFO){ const el=labelEls[z];
    if (!zShow){ el.style.opacity=0; continue; }
    _v.set(ZINFO[z].cx, 13, ZINFO[z].cz).project(cam); toScreen(el);
    el.style.opacity = z===hoveredZone ? 1 : 0.9;
    el.style.transform = `translate(-50%,-50%) scale(${z===hoveredZone?1.18:1})`; }
  // raft "back" label — floats over the log raft in overview
  if (zShow){ _v.set(RAFT_W.x, 3.2, RAFT_W.z).project(cam); toScreen(raftEl);
    raftEl.style.opacity = raftHover ? 1 : 0.85;
    raftEl.style.transform = `translate(-50%,-50%) scale(${raftHover?1.18:1})`; }
  else raftEl.style.opacity = 0;
  // building name labels — only in the active zone (zone view)
  for (const [key, gx, gy] of LAYOUT){ const el=bldgEls[key];
    const bShow = viewState==='zone' && ZONES[activeZone]?.members.includes(key);
    if (!bShow){ el.style.opacity=0; continue; }
    _v.set(wx(gx+1), (HEIGHTS[key]||14)+3.5, wz(gy+1)).project(cam); toScreen(el);
    el.style.opacity = key===hoveredBldg ? 1 : 0.92;
    el.style.transform = `translate(-50%,-50%) scale(${key===hoveredBldg?1.14:1})`; } }

// ── content panel ──
const CONTENT = {
  art:           { title:'art',                   url:'/creative' },
  blog1:         { title:'recent posts',          url:'/blog-archive' },
  cards:         { title:'game design',           url:'/creative' },
  blog4:         { title:'archive',               url:'/blog-archive' },
  project1:      { title:'misc',             url:'/cs/misc' },
  project2:      { title:'game development', url:'/cs/gamedev' },
  research1:     { title:'robotics',             url:'/cs/research/robotics' },
  research2:     { title:'ubiquitous computing', url:'/cs/research/ubicomp' },
  resumeBuilding:{ title:'resume',     url:'/Pages/Materials/Resume_June_28.pdf' },
  transcript:    { title:'transcript', url:'/Pages/Materials/Transcripts/Aye_transcript_soph.pdf' },
  infobuilding:  { title:'about me', url:'/site' },   // the pastel-green folder shows the real homepage
};
const panel = document.getElementById('panel');
const pbody = panel.querySelector('.pbody');
// per-zone folder color (creative = beige, then pastels): the cover + folder body tint to this.
const FOLDER = { creative:'#e7d6a6', about:'#c3ddb6', projects:'#f2cea0', materials:'#bcd4ec', research:'#d7c5e9' };
// building click → the folder cover slides down to reveal the LIVE page inside.
let _hideT = 0;
function showPanel(key){ const c = CONTENT[key] || { title:key };
  clearTimeout(_hideT); panel.classList.remove('exit');                   // cancel any in-flight close
  panel.querySelector('.ptitle').textContent = '> ' + (c.title || key);
  panel.style.setProperty('--accent', ZONES[activeZone]?.color || '#a8c7fa');
  panel.style.setProperty('--folder', FOLDER[activeZone] || '#e7d6a6');
  pbody.classList.remove('loaded','pad');
  if (c.url){ pbody.innerHTML = `<iframe src="${c.url}"></iframe>`;        // live iframe → generalizable to any page
    pbody.querySelector('iframe').addEventListener('load', () => pbody.classList.add('loaded'), { once:true }); }
  else { pbody.classList.add('pad'); pbody.innerHTML = c.html || ''; }
  panel.classList.add('active');                                          // closed folder appears…
  requestAnimationFrame(() => requestAnimationFrame(() => panel.classList.add('open')));   // …cover slides open
}
// close = the WHOLE folder slides smoothly down off the screen (not the cover re-closing then vanishing)
function hidePanel(){ panel.classList.add('exit');
  _hideT = setTimeout(() => { panel.classList.remove('active','open','exit'); pbody.innerHTML=''; pbody.classList.remove('loaded'); }, 620); }

// ── state machine ──
let viewState = 'overview', activeZone = null, hoveredZone = null, hoveredBldg = null;
const backBtn = document.getElementById('back');
function showBack(){ backBtn.classList.toggle('show', viewState !== 'overview'); }
// ── the log raft (screen bottom-left, on the water) sails you back to the CRT lobby ──
const RAFT_W = { x: RAFT.X - HALF, z: RAFT.Z - HALF };
let raftHover = false, _leaving = false;
function overRaft(){ return Math.hypot(hitPt.x - RAFT_W.x, hitPt.z - RAFT_W.z) < 8; }   // hitPt = last ground raycast
function goToMonitor(){ if (_leaving) return; _leaving = true;
  document.getElementById('fade').classList.add('on');
  tweenTo(cur.t.clone(), cur.span * 1.22);                        // gentle pull-back while the room fades in
  setTimeout(() => { window.location.href = '/'; }, 520); }

const ray = new THREE.Raycaster(), ndc = new THREE.Vector2(), hitPt = new THREE.Vector3();
const groundPlane = new THREE.Plane(new THREE.Vector3(0,1,0), 0);
function groundGrid(ev){ ndc.x=(ev.clientX/innerWidth)*2-1; ndc.y=-(ev.clientY/innerHeight)*2+1; ray.setFromCamera(ndc, cam);
  if (!ray.ray.intersectPlane(groundPlane, hitPt)) return null; return { gx:(hitPt.x+HALF)/TILE, gy:(hitPt.z+HALF)/TILE }; }
function pickBldg(ev){ let best=null, bd=1e9; const keys = activeZone ? ZONES[activeZone].members : LAYOUT.map(l=>l[0]);
  for (const key of keys){ const e=LAYOUT.find(l=>l[0]===key); if(!e)continue;
    _v.set(wx(e[1]+1), 5, wz(e[2]+1)).project(cam); const px=(_v.x*0.5+0.5)*innerWidth, py=(-_v.y*0.5+0.5)*innerHeight;
    const dd=Math.hypot(px-ev.clientX, py-ev.clientY); if(dd<bd){ bd=dd; best={key,gx:e[1],gy:e[2]}; } }
  const rad = Math.max(48, innerHeight*6/cur.span); return best && bd<rad ? best : null; }

function enterZone(z){
  if (z==='about'){   // about = a single building: one click zooms (zone-level) AND opens the green folder
    activeZone='about'; hoveredZone=null; setBorder(null);
    const e=LAYOUT.find(l=>l[0]==='infobuilding'); openBuilding('infobuilding', e[1], e[2]); return; }
  activeZone=z; viewState='zone'; hoveredZone=null; setBorder(null);
  tweenTo(new THREE.Vector3(ZINFO[z].cx, 4, ZINFO[z].cz), ZINFO[z].span); showBack(); need=true; }
function openBuilding(key, gx, gy){ viewState='building'; hoveredBldg=null; setRing(null);
  const span = key==='infobuilding' ? ZINFO.about.span : 13;   // about zooms only to zone level (not fully in)
  tweenTo(new THREE.Vector3(wx(gx+1), 6, wz(gy+1)), span); showPanel(key); showBack(); need=true; }
function back(){ hidePanel();
  if (viewState==='building' && activeZone==='about'){   // about opened straight from overview → go straight back
    viewState='overview'; activeZone=null; hoveredBldg=null; setRing(null); tweenTo(OVERVIEW.t.clone(), OVERVIEW.span); }
  else if (viewState==='building'){ viewState='zone'; const z=activeZone; tweenTo(new THREE.Vector3(ZINFO[z].cx,4,ZINFO[z].cz), ZINFO[z].span); }
  else if (viewState==='zone'){ viewState='overview'; activeZone=null; hoveredBldg=null; setRing(null); tweenTo(OVERVIEW.t.clone(), OVERVIEW.span); }
  showBack(); need=true; }

// PERF: hover picking runs once per frame off recorded coords (pointermove can fire at 120–250Hz)
let _hvX = 0, _hvY = 0, _hvDirty = false, _cursor = '';
renderer.domElement.addEventListener('pointermove', ev => { _hvX = ev.clientX; _hvY = ev.clientY; _hvDirty = true; });
function setCursor(c){ if (c !== _cursor){ _cursor = c; document.body.style.cursor = c; } }
function pollHover(){
  if (!_hvDirty) return; _hvDirty = false;
  const ev = { clientX:_hvX, clientY:_hvY };
  if (viewState==='overview'){ const g=groundGrid(ev); const z=g?zoneAt(Math.floor(g.gx),Math.floor(g.gy)):null;
    const r=!!g && overRaft();
    if (r!==raftHover){ raftHover=r; _uiDirty=true; }
    if (z!==hoveredZone){ hoveredZone=z; setBorder(z); need=true; _rtDirty=true; _uiDirty=true; } setCursor((z||r)?'pointer':'default'); }
  else if (viewState==='zone'){ const b=pickBldg(ev); const k=b?b.key:null;
    if (k!==hoveredBldg){ hoveredBldg=k; setRing(k); need=true; _rtDirty=true; _uiDirty=true; } setCursor(k?'pointer':'default'); }
  else setCursor('default');
}
renderer.domElement.addEventListener('click', ev => {
  if (viewState==='overview'){ const g=groundGrid(ev);
    if (g && overRaft()){ goToMonitor(); return; }
    const z=g?zoneAt(Math.floor(g.gx),Math.floor(g.gy)):null; if (z) enterZone(z); }
  else if (viewState==='zone'){ const b=pickBldg(ev); if (b) openBuilding(b.key, b.gx, b.gy); else back(); }
  else if (viewState==='building'){ back(); }
});
backBtn.addEventListener('click', back);
panel.querySelector('.pclose').addEventListener('click', back);
addEventListener('keydown', e => { if (e.key==='Escape') back(); });

// debug handles for screenshots
Object.assign(window, { cam, scene, renderer, enterZone, openBuilding, back,
  hoverZone: z => { viewState='overview'; hoveredZone=z; setBorder(z); need=true; _rtDirty=true; _uiDirty=true; },
  _state: () => ({ viewState, activeZone, hoveredZone }) });

const hudEl = document.getElementById('hud');
function hud(){ hudEl.textContent = `voxmap · ${counts.tris.toLocaleString()} tris · ${renderer.info.render.calls} calls · ${viewState}${activeZone?' · '+activeZone:''}`; }

let _frameNo = 0;
function draw(now){
  pollRipplePointer(now); pollHover();                     // pointer work coalesced to once per frame
  simTick(now);                                            // ripple field: steps only while awake, sleeps when calm
  updateWaterUniforms();
  // re-render the SCENE RTs only when they changed; the hover PULSE (a slow opacity sine) refreshes at
  // half rate — imperceptible on a ~1.3s pulse, halves the hover cost. Idle frames re-run only the
  // cheap water + post chain.
  if (_rtDirty || anim || ((hoveredZone || hoveredBldg) && (_frameNo & 1) === 0)){
    renderRTs(!(_rtDirty || anim)); if (!anim) _rtDirty = false; }   // pulse-only refresh skips the sky RT
  if (anim || _uiDirty){ updateLabels(); hud(); _uiDirty = false; }   // DOM writes only when something changed
  updateGodrays(); renderRays(); composer.render();
  if (!firstRendered){ renderer.shadowMap.autoUpdate = false; firstRendered = true; } }
// water animates every frame; the expensive island/sky renders are cached above
let _t0 = performance.now(), _clk = 0;
function loop(now){ requestAnimationFrame(loop);
  if (anim){ const k=Math.min(1,(performance.now()-anim.t0)/anim.dur), e=ease(k);
    cur.t.lerpVectors(anim.fromT, anim.toT, e); cur.span = anim.fromSpan + (anim.toSpan-anim.fromSpan)*e; applyCam(); if (k>=1){ anim=null; _rtDirty=true; _uiDirty=true; } }
  if (hoveredZone) borderMat.opacity = 0.72 + 0.13*Math.sin(performance.now()*0.005);   // floor >0.5 so the rim never sinks under the water
  if (hoveredBldg) ringMat.opacity   = 0.85 + 0.15*Math.sin(performance.now()*0.006);
  const _dtq = now - _t0;
  waterPass.uniforms.uTime.value += _dtq * 0.0004; _t0 = now; _clk += 0.016;
  qualityTick(_dtq);
  vgPass.uniforms.time.value = _clk; rayGenMat.uniforms.uTime.value = _clk;
  draw(now); _frameNo++;
}
requestAnimationFrame(loop);

/* ── adaptive quality: weak GPUs step the render scale down until frames are smooth; the canvas is
      CSS-stretched to full size (film grain + soft post hide it). Sticky per session; `?q=0.7` forces. ── */
const QSTEPS = [1, 0.85, 0.7, 0.55];
const _qForce = parseFloat(new URLSearchParams(location.search).get('q'));
let _qi = QSTEPS.indexOf(_qForce >= 0 ? _qForce : parseFloat(sessionStorage.getItem('voxQ')));
if (_qi < 0) _qi = 0;
function sizeAll(){
  const s = QSTEPS[_qi], w = Math.max(2, Math.round(innerWidth*s)), h = Math.max(2, Math.round(innerHeight*s));
  renderer.setSize(w, h, false);
  renderer.domElement.style.width = innerWidth + 'px'; renderer.domElement.style.height = innerHeight + 'px';
  composer.setSize(w, h); makeRTs(w, h); makeRayRT(w, h);
  godrays.enabled = _qi < QSTEPS.length - 1;   // floor tier: drop the god rays too
  applyCam(); need = true; _rtDirty = true; _uiDirty = true;
}
addEventListener('resize', sizeAll);
sizeAll();
let _qWarm = 0; const _qBuf = [];
function qualityTick(dt){
  if (dt > 250 || _qi >= QSTEPS.length - 1 || !isNaN(_qForce)) return;   // background tabs / forced tier
  if (++_qWarm < 180) return;                                            // ignore load + shader-compile jank
  _qBuf.push(dt);
  if (_qBuf.length >= 90){
    _qBuf.sort((a, b) => a - b); const med = _qBuf[45]; _qBuf.length = 0;
    if (med > 22){ _qi++; sessionStorage.setItem('voxQ', String(QSTEPS[_qi])); sizeAll(); _qWarm = 120; }
  }
}

/* film-grain overlay texture (generated once) */
{ const gc=document.createElement('canvas'); gc.width=gc.height=160; const g=gc.getContext('2d');
  const id=g.createImageData(160,160), d=id.data;
  for(let i=0;i<d.length;i+=4){ const v=Math.random()*255; d[i]=d[i+1]=d[i+2]=v; d[i+3]=255; }
  g.putImageData(id,0,0); document.getElementById('grain').style.backgroundImage=`url(${gc.toDataURL()})`; }
</script>
</body>
</html>
