// exposure + lights are driven by setTimeOfDay() in the shading engine (below the lighting rig)

/* ====================== helpers ====================== */
function mixHex(a,b,t){
  const pa=parseInt(a.slice(1),16), pb=parseInt(b.slice(1),16);
  const ar=(pa>>16)&255, ag=(pa>>8)&255, ab=pa&255, br=(pb>>16)&255, bg=(pb>>8)&255, bb=pb&255;
  const r=Math.round(ar+(br-ar)*t), g=Math.round(ag+(bg-ag)*t), l=Math.round(ab+(bb-ab)*t);
  return '#'+((1<<24)|(r<<16)|(g<<8)|l).toString(16).slice(1);
}
function makeMatcapSoft(hi, mid, sh, rim){
  const s=512, cv=document.createElement('canvas'); cv.width=cv.height=s; const c=cv.getContext('2d');
  c.fillStyle=sh; c.fillRect(0,0,s,s);
  const g=c.createRadialGradient(s*0.40,s*0.34,s*0.02, s*0.50,s*0.55,s*0.62);
  g.addColorStop(0.00,hi); g.addColorStop(0.16,mixHex(hi,mid,0.35)); g.addColorStop(0.40,mid);
  g.addColorStop(0.62,mixHex(mid,sh,0.45)); g.addColorStop(0.82,mixHex(mid,sh,0.80)); g.addColorStop(1.00,sh);
  c.fillStyle=g; c.beginPath(); c.arc(s/2,s/2,s/2,0,7); c.fill();
  const r=c.createRadialGradient(s*0.72,s*0.76,s*0.02, s*0.72,s*0.76,s*0.58);
  r.addColorStop(0,rim); r.addColorStop(0.5,'rgba(0,0,0,0)'); r.addColorStop(1,'rgba(0,0,0,0)');
  c.globalCompositeOperation='lighter'; c.fillStyle=r; c.beginPath(); c.arc(s/2,s/2,s/2,0,7); c.fill();
  const sp=c.createRadialGradient(s*0.36,s*0.30,0, s*0.36,s*0.30,s*0.18);
  sp.addColorStop(0,'rgba(255,255,255,0.45)'); sp.addColorStop(0.5,'rgba(255,255,255,0.10)'); sp.addColorStop(1,'rgba(255,255,255,0)');
  c.fillStyle=sp; c.beginPath(); c.arc(s/2,s/2,s/2,0,7); c.fill();
  c.globalCompositeOperation='source-over';
  const t=new THREE.CanvasTexture(cv); t.colorSpace=THREE.SRGBColorSpace;
  t.minFilter=THREE.LinearMipmapLinearFilter; t.magFilter=THREE.LinearFilter; t.generateMipmaps=true;
  t.anisotropy=renderer.capabilities.getMaxAnisotropy(); t.needsUpdate=true; return t;
}
function makeNormalMap(size=256, bump=0.5, freq=3){
  const s=size, cv=document.createElement('canvas'); cv.width=cv.height=s;
  const c=cv.getContext('2d'); const img=c.createImageData(s,s); const d=img.data;
  const G=64; const base=new Float32Array((G+1)*(G+1));
  for(let i=0;i<base.length;i++) base[i]=Math.random();
  const sample=(u,v)=>{ u*=G; v*=G;
    const x0=((Math.floor(u)%G)+G)%G, y0=((Math.floor(v)%G)+G)%G, x1=(x0+1)%G, y1=(y0+1)%G;
    const fx=u-Math.floor(u), fy=v-Math.floor(v), sx=fx*fx*(3-2*fx), sy=fy*fy*(3-2*fy);
    const a=base[y0*(G+1)+x0], b=base[y0*(G+1)+x1], e=base[y1*(G+1)+x0], f=base[y1*(G+1)+x1];
    return (a*(1-sx)+b*sx)*(1-sy)+(e*(1-sx)+f*sx)*sy; };
  const H=(u,v)=>{ let h=0,amp=1,fr=freq,sum=0; for(let o=0;o<3;o++){ h+=sample(u*fr,v*fr)*amp; sum+=amp; amp*=0.5; fr*=2; } return h/sum; };
  const eps=1/s;
  for(let y=0;y<s;y++) for(let x=0;x<s;x++){
    const u=x/s, v=y/s, hL=H(u-eps,v), hR=H(u+eps,v), hD=H(u,v-eps), hU=H(u,v+eps);
    let nx=(hL-hR)*bump, ny=(hD-hU)*bump, nz=1.0; const inv=1/Math.hypot(nx,ny,nz); nx*=inv; ny*=inv; nz*=inv;
    const i=(y*s+x)*4; d[i]=Math.round((nx*0.5+0.5)*255); d[i+1]=Math.round((ny*0.5+0.5)*255); d[i+2]=Math.round((nz*0.5+0.5)*255); d[i+3]=255;
  }
  c.putImageData(img,0,0);
  const t=new THREE.CanvasTexture(cv); t.colorSpace=THREE.NoColorSpace;
  t.wrapS=t.wrapT=THREE.RepeatWrapping; t.repeat.set(2,2); t.anisotropy=renderer.capabilities.getMaxAnisotropy(); t.needsUpdate=true; return t;
}
function pillowBox(w,h,d,seg=12,radius=0.34,bulge=0.17){
  const geo=new RoundedBoxGeometry(w,h,d,seg,radius); const hx=w/2,hy=h/2,hz=d/2; const p=geo.attributes.position;
  for(let i=0;i<p.count;i++){
    const x=p.getX(i),y=p.getY(i),z=p.getZ(i), u=x/hx,v=y/hy,q=z/hz; const c2=t=>Math.max(0,1-t*t);
    const fz=Math.sign(z)*bulge*c2(u)*c2(v), fx=Math.sign(x)*bulge*0.45*c2(v)*c2(q), fy=Math.sign(y)*bulge*0.35*c2(u)*c2(q);
    p.setXYZ(i, x+fx, y+fy, z+fz);
  }
  p.needsUpdate=true; geo.computeVertexNormals(); return geo;
}
function domedRect(w,h,seg=48,bulge=0.18){
  const geo=new THREE.PlaneGeometry(w,h,seg,seg); const hx=w/2,hy=h/2; const p=geo.attributes.position;
  for(let i=0;i<p.count;i++){ const x=p.getX(i),y=p.getY(i),u=x/hx,v=y/hy; p.setZ(i, bulge*Math.max(0,1-u*u)*Math.max(0,1-v*v)); }
  p.needsUpdate=true; geo.computeVertexNormals(); return geo;
}
/* rounded-rect plane with 0..1 UVs (so the screen corners match the round bezel) */
function roundedRectGeo(w,h,r){
  const sh=new THREE.Shape(); const x=-w/2,y=-h/2;
  sh.moveTo(x+r,y); sh.lineTo(x+w-r,y); sh.quadraticCurveTo(x+w,y,x+w,y+r);
  sh.lineTo(x+w,y+h-r); sh.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  sh.lineTo(x+r,y+h); sh.quadraticCurveTo(x,y+h,x,y+h-r);
  sh.lineTo(x,y+r); sh.quadraticCurveTo(x,y,x+r,y);
  const geo=new THREE.ShapeGeometry(sh, 14);
  const pos=geo.attributes.position, uv=geo.attributes.uv;
  for(let i=0;i<pos.count;i++) uv.setXY(i,(pos.getX(i)+w/2)/w,(pos.getY(i)+h/2)/h);
  uv.needsUpdate=true; return geo;
}
/* a rounded-rect RING (band) — outer ow×oh, inner hole iw×ih — to exactly outline a screen/window */
function ringGeo(ow,oh,iw,ih,r){
  const rr=(p,w,h,rad)=>{ const x=-w/2,y=-h/2;
    p.moveTo(x+rad,y); p.lineTo(x+w-rad,y); p.quadraticCurveTo(x+w,y,x+w,y+rad);
    p.lineTo(x+w,y+h-rad); p.quadraticCurveTo(x+w,y+h,x+w-rad,y+h);
    p.lineTo(x+rad,y+h); p.quadraticCurveTo(x,y+h,x,y+h-rad);
    p.lineTo(x,y+rad); p.quadraticCurveTo(x,y,x+rad,y); };
  const sh=new THREE.Shape(); rr(sh,ow,oh,r);
  const hole=new THREE.Path(); rr(hole,iw,ih,Math.max(0.02,r*0.85));
  sh.holes.push(hole); return new THREE.ShapeGeometry(sh);
}
function makeLabel(text){
  const W=512,H=140,cv=document.createElement('canvas'); cv.width=W; cv.height=H; const c=cv.getContext('2d');
  c.clearRect(0,0,W,H); c.font='700 70px "JetBrains Mono", monospace'; c.textAlign='center'; c.textBaseline='middle';
  c.fillStyle='rgba(255,250,240,0.22)'; c.fillText(text, W/2+2, H/2+3);
  c.fillStyle='rgba(70,58,48,0.9)'; c.fillText(text, W/2, H/2);
  const t=new THREE.CanvasTexture(cv); t.colorSpace=THREE.SRGBColorSpace; t.anisotropy=renderer.capabilities.getMaxAnisotropy(); return t;
}
function makeGlowRing(rgb){
  const W=512,H=400,cv=document.createElement('canvas'); cv.width=W; cv.height=H; const c=cv.getContext('2d');
  c.clearRect(0,0,W,H); const r=44,x=34,y=34,w=W-68,h=H-68;
  c.strokeStyle=rgb; c.lineWidth=8; c.shadowColor=rgb;
  for(const blur of [44,22,10]){ c.shadowBlur=blur;
    c.beginPath(); c.moveTo(x+r,y); c.arcTo(x+w,y,x+w,y+h,r); c.arcTo(x+w,y+h,x,y+h,r); c.arcTo(x,y+h,x,y,r); c.arcTo(x,y,x+w,y,r); c.closePath(); c.stroke(); }
  const t=new THREE.CanvasTexture(cv); t.colorSpace=THREE.SRGBColorSpace; return t;
}

/* matcaps + materials */
const mcNormal=makeNormalMap(256,0.5,3);
/* ============ SHADING ENGINE: IBL environment + reusable PBR material factory ============ */
const _pmrem=new THREE.PMREMGenerator(renderer);
function buildGradientEnv(top,horizon,bottom,sunRGBA,sunAz=0){
  const w=1024,h=512,cv=document.createElement('canvas'); cv.width=w; cv.height=h; const c=cv.getContext('2d');
  const g=c.createLinearGradient(0,0,0,h); g.addColorStop(0,top); g.addColorStop(0.55,horizon); g.addColorStop(1,bottom);
  c.fillStyle=g; c.fillRect(0,0,w,h);
  const sx=(sunAz/(Math.PI*2)+0.5)*w, sy=h*0.42;
  const lobe=c.createRadialGradient(sx,sy,0,sx,sy,w*0.22); lobe.addColorStop(0,sunRGBA); lobe.addColorStop(1,'rgba(0,0,0,0)');
  c.globalCompositeOperation='lighter'; c.fillStyle=lobe; c.beginPath(); c.arc(sx,sy,w*0.22,0,7); c.fill(); c.globalCompositeOperation='source-over';
  const tex=new THREE.CanvasTexture(cv); tex.mapping=THREE.EquirectangularReflectionMapping; tex.colorSpace=THREE.SRGBColorSpace;
  const env=_pmrem.fromEquirectangular(tex).texture; tex.dispose(); return env;
}
scene.environment=buildGradientEnv('#ead9c4','#cdbfc3','#241c22','rgba(255,224,176,0.9)',0);
scene.environmentIntensity=1.0;
_pmrem.dispose();
const _normal=mcNormal;
function surface(o={}){
  const m=new THREE.MeshStandardMaterial({ color:new THREE.Color(o.color??0xffffff), roughness:o.roughness??0.7, metalness:o.metalness??0.0, envMapIntensity:o.envMapIntensity??1.0, fog:o.fog??true });
  if(o.normal!==false){ m.normalMap=_normal; const ns=o.normalScale??0.12; m.normalScale.set(ns,ns); }
  if(o.emissive){ m.emissive=new THREE.Color(o.emissive); m.emissiveIntensity=o.emissiveIntensity??1; }
  return m;
}
function varnish(o={}){
  const m=new THREE.MeshPhysicalMaterial({ color:new THREE.Color(o.color??0xffffff), roughness:o.roughness??0.55, metalness:o.metalness??0.0, envMapIntensity:o.envMapIntensity??1.0, clearcoat:o.clearcoat??0.4, clearcoatRoughness:o.clearcoatRoughness??0.32, fog:o.fog??true });
  if(o.normal!==false){ m.normalMap=_normal; const ns=o.normalScale??0.1; m.normalScale.set(ns,ns); }
  return m;
}
const beige=surface({color:0xd9ccb0, roughness:0.56, envMapIntensity:1.20, normalScale:0.16});  // CRT shell
const beigeDark=surface({color:0xc1b291, roughness:0.60, envMapIntensity:1.05, normalScale:0.12}); // neck
const frameMat=surface({color:0x191a1f, roughness:0.45, envMapIntensity:0.95, normal:false});      // dark bezel
const woodMat=varnish({color:0x6a4528, roughness:0.55, clearcoat:0.22, clearcoatRoughness:0.40, envMapIntensity:0.7, normalScale:0.08}); // desk
const plasterMat=surface({color:0xe4dcd4, roughness:0.96, envMapIntensity:0.80, normalScale:0.06}); // white wall
const winFrameMat=surface({color:0xe7dccb, roughness:0.55, envMapIntensity:1.0, normalScale:0.08, emissive:0xfff0dc, emissiveIntensity:0}); // casing (glows on window hover)

/* ====================== screen canvas (terminal) ====================== */
const sc=document.createElement('canvas'); sc.width=1024; sc.height=768;
const sx=sc.getContext('2d');
const screenTex=new THREE.CanvasTexture(sc); screenTex.colorSpace=THREE.SRGBColorSpace;
function drawStatic(amt){
  const n=Math.floor(amt*1400); sx.save(); sx.globalAlpha=0.5;
  for(let k=0;k<n;k++){ const v=Math.random(); sx.fillStyle=v<.5?'#0a1a12':(v<.8?'#16331f':'#2c5a3a'); sx.fillRect(Math.random()*1024,Math.random()*768,3,2); }
  sx.restore();
}
function clockStr(){ const d=new Date(); let h=d.getHours(); const m=d.getMinutes(); const ap=h<12?'AM':'PM'; h=h%12||12; return h+':'+String(m).padStart(2,'0')+' '+ap; }
function drawScreen(){
  const W=1024,H=768;
  sx.fillStyle='#040d08'; sx.fillRect(0,0,W,H);
  const bg=sx.createRadialGradient(W/2,H*0.42,40,W/2,H*0.5,H*0.8);
  bg.addColorStop(0,'rgba(20,60,40,.45)'); bg.addColorStop(1,'rgba(2,8,5,0)'); sx.fillStyle=bg; sx.fillRect(0,0,W,H);
  if(state==='off'){
    drawStatic(0.03);
    sx.fillStyle='rgba(91,255,158,.55)'; sx.font="24px 'JetBrains Mono', monospace"; sx.textAlign='center';
    sx.shadowColor='#5bff9e'; sx.shadowBlur=10; sx.fillText('click to power on', W/2, H*0.55); sx.shadowBlur=0; sx.textAlign='left';
  } else if(state==='loading'){
    // ── boot-up screen: "booting.." + a chunky segmented progress bar, then the site loads ──
    drawStatic(0.05);
    const cx=W/2, dots='.'.repeat(1+Math.floor(performance.now()/380)%3);
    sx.textAlign='center'; sx.textBaseline='top'; sx.font="36px 'JetBrains Mono', monospace";
    for(let pass=0;pass<2;pass++){ sx.shadowColor='#5bff9e'; sx.shadowBlur=pass===0?24:6;
      sx.fillStyle=pass===0?'rgba(91,255,158,.5)':'#82ffba'; sx.fillText('booting'+dots, cx, H*0.40); }
    const bw=W*0.5, bh=36, bx0=cx-bw/2, by0=H*0.53, SEGS=24, sw=(bw-12)/SEGS;
    sx.shadowColor='#5bff9e'; sx.shadowBlur=10; sx.strokeStyle='#82ffba'; sx.lineWidth=3; sx.strokeRect(bx0,by0,bw,bh);
    sx.fillStyle='#5bff9e';
    for(let i=0;i<Math.floor(bootP*SEGS);i++) sx.fillRect(bx0+6+i*sw+1, by0+6, sw-2, bh-12);
    sx.font="22px 'JetBrains Mono', monospace"; sx.fillStyle='#7fffb8';
    sx.fillText(Math.floor(bootP*100)+'%', cx, by0+bh+16);
    sx.shadowBlur=0; sx.textAlign='left';
  } else {
    drawStatic(state==='powering'?0.6:0.04);
