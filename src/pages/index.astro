    text-shadow:0 0 10px rgba(91,255,158,.7);transform:translate(-50%,-50%);user-select:none;opacity:.8;transition:opacity .15s}
  #skip:hover{opacity:1}
  /* ── the SITE rendered ON the monitor: an iframe pinned to the projected screen quad, with a
        slight CRT treatment (scanlines + vignette + glass glare); the bezel stays visible around it.
        Sits UNDER #grain (z 30) so the film grain doubles as CRT noise. Click the room to step back. ── */
  #siteScreen{position:fixed;z-index:15;display:none;overflow:hidden;background:#0a0f0c;
    box-shadow:0 0 46px rgba(91,255,158,.13), 0 0 8px rgba(91,255,158,.20)}
  #siteScreen.on{display:block}
  #siteScreen iframe{width:100%;height:100%;border:0;display:block;background:#fbfaf6;opacity:0;transition:opacity .45s ease}
  #siteScreen iframe.ld{opacity:1}
  #siteScreen .crtfx{position:absolute;inset:0;pointer-events:none;border-radius:inherit;
    background:repeating-linear-gradient(0deg, rgba(0,0,0,0.05) 0px, rgba(0,0,0,0.05) 1px, transparent 1px, transparent 3px);
    box-shadow:inset 0 0 110px rgba(8,22,14,.30), inset 0 0 18px rgba(91,255,158,.08)}
  #siteScreen .crtfx::after{content:'';position:absolute;inset:0;border-radius:inherit;
    background:radial-gradient(120% 90% at 30% 6%, rgba(255,255,255,.06), transparent 55%)}
</style>
