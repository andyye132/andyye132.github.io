    for(let pass=0;pass<2;pass++){
      sx.shadowColor='#5bff9e'; sx.shadowBlur=pass===0?24:6; sx.fillStyle=pass===0?'rgba(91,255,158,.5)':'#82ffba';
      let y=padY; for(const line of displayed){ sx.fillText(line,padX,y); y+=lineH; }
    }
    sx.shadowBlur=0;
