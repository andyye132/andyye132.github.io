function shapeWithHole(W,H,winW,winH,r){
  const sh=new THREE.Shape();
  sh.moveTo(-W/2,-H/2); sh.lineTo(W/2,-H/2); sh.lineTo(W/2,H/2); sh.lineTo(-W/2,H/2); sh.lineTo(-W/2,-H/2);
  const hole=new THREE.Path(); const x=-winW/2,y=-winH/2;
  hole.moveTo(x+r,y); hole.lineTo(x+winW-r,y); hole.quadraticCurveTo(x+winW,y,x+winW,y+r);
  hole.lineTo(x+winW,y+winH-r); hole.quadraticCurveTo(x+winW,y+winH,x+winW-r,y+winH);
  hole.lineTo(x+r,y+winH); hole.quadraticCurveTo(x,y+winH,x,y+winH-r);
  hole.lineTo(x,y+r); hole.quadraticCurveTo(x,y,x+r,y);
  sh.holes.push(hole); return new THREE.ShapeGeometry(sh);
}
