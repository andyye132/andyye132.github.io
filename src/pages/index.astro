/* ---- real local (PST) time drives the window: sun (day) vs moon (night) ---- */
function nowHour(){ const d=new Date(); return d.getHours()+d.getMinutes()/60; }   // viewer's real local time
function smooth01(a,b,x){ x=Math.max(0,Math.min(1,(x-a)/(b-a))); return x*x*(3-2*x); }
const _ft = new URLSearchParams(location.search).get('t');   // ?t=day / ?t=night to preview
let nowH = _ft==='day' ? 12 : _ft==='night' ? 0 : nowHour();
let dayAmt = smooth01(5.5,8.0,nowH)*(1.0-smooth01(17.5,20.5,nowH));   // 0 night .. 1 day (refreshed live)
const SUN=new THREE.Vector3(1.0,0.85,0.64), MOON=new THREE.Vector3(0.60,0.77,1.0);
