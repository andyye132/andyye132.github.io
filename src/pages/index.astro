  #hint{position:fixed;left:0;right:0;bottom:26px;z-index:40;text-align:center;color:#f3d9e6;font-size:12px;letter-spacing:3px;
    opacity:0;text-shadow:0 0 10px rgba(237,193,203,.5);transition:opacity .4s;pointer-events:none}
