  uLightOn:{value:1.0}, uTime:{value:0.0} };
const _grVert=`varying vec2 vUv; void main(){ vUv=uv; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0); }`;
const _grGen=new THREE.ShaderMaterial({
  uniforms:{ tScene:{value:null}, lightPos:_grU.lightPos, density:_grU.density, weight:_grU.weight,
    decay:_grU.decay, exposure:_grU.exposure, uThresh:_grU.uThresh, uTime:_grU.uTime },
  vertexShader:_grVert,
  fragmentShader:`#define SAMPLES 64
    uniform sampler2D tScene; uniform vec2 lightPos;
    uniform float density,weight,decay,exposure,uThresh,uTime; varying vec2 vUv;
    void main(){ vec2 delta=(vUv-lightPos)*(density/float(SAMPLES)); vec2 coord=vUv;
      float dith=fract(sin(dot(vUv,vec2(12.9898,78.233))+uTime)*43758.5453); coord-=delta*dith;
