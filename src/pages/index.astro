const vgPass=new ShaderPass(Grade);
const composer=new EffectComposer(renderer);
composer.addPass(new RenderPass(scene, camera));
composer.addPass(godrays);
const bloom=new UnrealBloomPass(new THREE.Vector2(innerWidth,innerHeight), 0.32, 0.45, 0.85);
composer.addPass(bloom);
composer.addPass(pixelPass);
composer.addPass(vgPass);
composer.addPass(new OutputPass());

/* day/night light colour + strength on the window god rays */
let _loadedDay = dayAmt>0.5;
function refreshTime(){   // keep the whole scene synced to the viewer's real local clock, live
  const ft=new URLSearchParams(location.search).get('t');
  nowH = ft==='day'?12 : ft==='night'?0 : nowHour();
  dayAmt = smooth01(5.5,8.0,nowH)*(1.0-smooth01(17.5,20.5,nowH));
  lightCol.copy(MOON).lerp(SUN, dayAmt);
  let af; if(nowH>=6&&nowH<18) af=(nowH-6)/12; else af=((nowH+6)%12)/12;
  const aa=(af-0.5)*Math.PI*0.84;
  LIGHT_WORLD.set(WIN.cx+Math.sin(aa)*WIN.w*0.42, WIN.cy+WIN.h*0.30+Math.cos(aa)*WIN.h*0.15, -9.0);
  disc.position.copy(LIGHT_WORLD); sunLight.position.copy(LIGHT_WORLD);
  discMat.uniforms.uColor.value.copy(lightCol); discMat.uniforms.uCore.value=3.6+(1.0-dayAmt)*1.0;
  godrays.uniforms.uColor.value.copy(lightCol); godrays.uniforms.exposure.value=0.38+(1.0-dayAmt)*0.22;  // gentle soft window glow (no shafts)
  setTimeOfDay(dayAmt);
  renderer.shadowMap.needsUpdate=true;   // scene is static — the frozen shadow map refreshes only when the sun moves (here, every 30s)
  if((dayAmt>0.5)!==_loadedDay){ _loadedDay=dayAmt>0.5; advImg.src=_loadedDay?'/voxworld-day.jpg':'/voxworld-night.jpg'; }
}
refreshTime();
setInterval(refreshTime, 30000);

const _proj=new THREE.Vector3(); const _glowDir=new THREE.Vector3();
function updateGodrays(){
  _proj.copy(LIGHT_WORLD).project(camera);
  const ux=_proj.x*0.5+0.5, uy=_proj.y*0.5+0.5; godrays.uniforms.lightPos.value.set(ux,uy);
  const inFront=_proj.z<1.0?1.0:0.0;
  const onX=THREE.MathUtils.smoothstep(ux,-0.35,0.05)*(1.0-THREE.MathUtils.smoothstep(ux,0.95,1.35));
  const onY=THREE.MathUtils.smoothstep(uy,-0.35,0.05)*(1.0-THREE.MathUtils.smoothstep(uy,0.95,1.35));
  godrays.uniforms.uLightOn.value=inFront*onX*onY;
  _glowDir.copy(LIGHT_WORLD).sub(camera.position).normalize(); backdrop.material.uniforms.uGlowDir.value.copy(_glowDir);
}

/* ====================== audio (synthesized) ====================== */
let actx=null, master=null, hum=null, muted=false;
const VOL=0.5;
function audioInit(){ if(actx) return; actx=new (window.AudioContext||window.webkitAudioContext)();
  master=actx.createGain(); master.gain.value=VOL; master.connect(actx.destination); }
function playKey(soft){ if(!actx||muted) return;
  const t=actx.currentTime, dur=0.03;
  const buf=actx.createBuffer(1,Math.ceil(actx.sampleRate*dur),actx.sampleRate), d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++) d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2);
  const s=actx.createBufferSource(); s.buffer=buf;
  const bp=actx.createBiquadFilter(); bp.type='bandpass'; bp.frequency.value=soft?900:1500+Math.random()*700; bp.Q.value=0.9;
  const g=actx.createGain(); g.gain.value=soft?0.05:0.10;
  s.connect(bp).connect(g).connect(master); s.start(t); s.stop(t+dur);
  const o=actx.createOscillator(); o.type='triangle'; o.frequency.value=soft?210:300+Math.random()*130;
  const og=actx.createGain(); og.gain.setValueAtTime(soft?0.04:0.07,t); og.gain.exponentialRampToValueAtTime(0.0001,t+0.025);
  o.connect(og).connect(master); o.start(t); o.stop(t+0.03);
}
function playPowerOn(){ if(!actx||muted) return; const t=actx.currentTime;
  const o=actx.createOscillator(); o.type='sine'; o.frequency.setValueAtTime(120,t); o.frequency.exponentialRampToValueAtTime(42,t+0.4);
  const g=actx.createGain(); g.gain.setValueAtTime(0.0001,t); g.gain.exponentialRampToValueAtTime(0.34,t+0.02); g.gain.exponentialRampToValueAtTime(0.0001,t+0.5);
  o.connect(g).connect(master); o.start(t); o.stop(t+0.55);
  const dur=0.5, buf=actx.createBuffer(1,Math.ceil(actx.sampleRate*dur),actx.sampleRate), dd=buf.getChannelData(0);
  for(let i=0;i<dd.length;i++) dd[i]=(Math.random()*2-1)*Math.pow(1-i/dd.length,1.5);
  const sb=actx.createBufferSource(); sb.buffer=buf; const hp=actx.createBiquadFilter(); hp.type='highpass'; hp.frequency.value=2200;
  const sg=actx.createGain(); sg.gain.value=0.06; sb.connect(hp).connect(sg).connect(master); sb.start(t); sb.stop(t+dur);
  const w=actx.createOscillator(); w.type='sine'; w.frequency.setValueAtTime(15000,t); w.frequency.exponentialRampToValueAtTime(8000,t+0.3);
  const wg=actx.createGain(); wg.gain.setValueAtTime(0.025,t); wg.gain.exponentialRampToValueAtTime(0.0001,t+0.35);
  w.connect(wg).connect(master); w.start(t); w.stop(t+0.4);
}
function startHum(){ if(!actx||hum||muted) return; hum=actx.createOscillator(); hum.type='sine'; hum.frequency.value=60;
  const hg=actx.createGain(); hg.gain.value=0.012; hum.connect(hg).connect(master); hum.start(); }

/* ====================== boot sequence + skip ====================== */
const sleep=ms=>new Promise(r=>setTimeout(r,ms));
function showReadyHint(){ const h=document.getElementById('hint'); h.textContent='click the screen  ·  or the world behind it'; h.style.opacity='1'; }
function fillAll(){ displayed=[]; for(const s of SCRIPT){ if(s.t==='line') displayed.push(s.s); else if(s.t==='blank') displayed.push(''); } cursorOn=true; state='ready'; showReadyHint(); }
async function runBoot(){
  if(skipped) return;
  state='booting'; displayed=[];
  for(const step of SCRIPT){
    if(skipped) return;
    if(step.t==='pause'){ await sleep(step.ms); continue; }
    if(step.t==='blank'){ displayed.push(''); await sleep(160); continue; }
    displayed.push(''); const i=displayed.length-1;
    for(const ch of step.s){ if(skipped) return; displayed[i]+=ch; playKey(ch===' '); await sleep(TYPE_MS+Math.random()*TYPE_JITTER); }
    await sleep(240);
  }
  state='ready'; showReadyHint();
}
function powerOn(){ audioInit(); if(actx.state==='suspended') actx.resume(); state='powering'; playPowerOn(); startHum(); setTimeout(()=>runBoot(), 520); }
function skipBoot(){ if(state==='ready'||state==='done') return; if(!actx){ powerOn(); } skipped=true; fillAll(); }

/* ====================== interaction + hover focus ====================== */
const ndc=new THREE.Vector2(); const ray=new THREE.Raycaster(); let mx=0, my=0;
function pick(e){ ndc.x=(e.clientX/innerWidth)*2-1; ndc.y=-(e.clientY/innerHeight)*2+1; ray.setFromCamera(ndc,camera);
  const hit=ray.intersectObjects([screen,worldBlur],false); return hit.length?hit[0].object.name:null; }
const tgt={ sGlow:0, wBlur:1, wRim:0, wBright:0.68, sDim:1 };
const cur={ sGlow:0, wBlur:1, wRim:0, wBright:0.68, sDim:1 };
function setFocus(f){
  if(f==='screen'){ tgt.sGlow=0.7; tgt.wBlur=1; tgt.wRim=0; tgt.wBright=0.42; tgt.sDim=1; }
  else if(f==='world'){ tgt.sGlow=0; tgt.wBlur=0.12; tgt.wRim=0.75; tgt.wBright=1.0; tgt.sDim=0.5; }
  else { tgt.sGlow=0; tgt.wBlur=1; tgt.wRim=0; tgt.wBright=0.56; tgt.sDim=1; }
}
addEventListener('pointermove', e=>{ mx=(e.clientX/innerWidth)*2-1; my=(e.clientY/innerHeight)*2-1;
  if(state==='ready'){ const t=pick(e); document.body.style.cursor=t?'pointer':'default'; setFocus(t||'none'); }
  else setFocus('none');
});
let transition=null, bootP=0, _bootSeg=-1, _revealNow=false;
const siteScreen=document.getElementById('siteScreen'), siteFrame=document.getElementById('siteFrame');
const _sc1=new THREE.Vector3();
function screenRectPx(){   // projected px rect of the CRT screen quad (mon y=0.35 + screen local (0,0.12,1.31), 3.18×2.38)
  const cy=0.47, cz=1.31, hw=1.59, hh=1.19;
  let minX=1e9,minY=1e9,maxX=-1e9,maxY=-1e9;
  for(const [sx,sy] of [[-1,-1],[1,-1],[1,1],[-1,1]]){
    _sc1.set(sx*hw, cy+sy*hh, cz).project(camera);
    const px=(_sc1.x*0.5+0.5)*innerWidth, py=(-_sc1.y*0.5+0.5)*innerHeight;
    if(px<minX)minX=px; if(px>maxX)maxX=px; if(py<minY)minY=py; if(py>maxY)maxY=py;
  }
  return {x:minX,y:minY,w:maxX-minX,h:maxY-minY};
}
function placeSiteScreen(){
  const r=screenRectPx();
  siteScreen.style.left=r.x+'px'; siteScreen.style.top=r.y+'px';
  siteScreen.style.width=r.w+'px'; siteScreen.style.height=r.h+'px';
  siteScreen.style.borderRadius=(r.w*0.042)+'px';   // matches the rounded screen geo
}
function showSiteScreen(){ placeSiteScreen(); siteScreen.classList.add('on'); }
function exitScreen(){   // click the room around the screen → step back out to the lobby
  siteScreen.classList.remove('on'); bootP=0; _bootSeg=-1; state='done';
  transition={which:'screenOut', t:0, t0:performance.now()};
}
function choose(which){
  if(state!=='ready') return; state='done'; document.getElementById('hint').style.opacity='0';
  const xf=document.getElementById('xfade'), xl=document.getElementById('xlabel');
  if(which==='screen'){
    // ── zoom + boot COMBO (~1.5s): dolly in while the boot bar fills; the site loads in the iframe
    //    meanwhile, and gets revealed ON the screen (with CRT fx) the moment the zoom lands. ──
    transition={which,t:0,t0:performance.now()};
    state='loading'; bootP=0; _bootSeg=-1;
    if(!siteFrame.src){ siteFrame.src='/site'; siteFrame.addEventListener('load',()=>siteFrame.classList.add('ld'),{once:true}); }
    return;
  }
  transition={which,t:0};
  xf.style.background='#0c0710'; xf.style.opacity='1'; xl.style.color='#5bff9e'; xl.textContent='→ entering the adventure…'; setTimeout(()=>xl.style.opacity='1',450);
  setTimeout(()=>{ window.location.href='/voxmap'; }, 1050);   // click the window → the 3D voxel island world
}
addEventListener('pointerdown', e=>{ if(e.target.id==='mute') return;
  if(transition && transition.which==='screen' && transition.shown){ exitScreen(); return; }   // click the room around the screen → back out (iframe clicks stay inside it)
  if(state==='off'){ powerOn(); return; }
  if(state==='booting'||state==='powering'){ skipBoot(); return; }
  if(state==='ready'){ const t=pick(e); if(t) choose(t==='screen'?'screen':'world'); } });
addEventListener('keydown', e=>{ if(e.key==='Enter') skipBoot(); else if(e.key==='p') pixelPass.enabled=!pixelPass.enabled; });
document.getElementById('mute').addEventListener('click', ()=>{ muted=!muted; document.getElementById('mute').textContent=muted?'♪ sound off':'♪ sound on'; if(master) master.gain.value=muted?0:VOL; });

/* ====================== loop ====================== */
let clock=0; const _skip=new THREE.Vector3();
function resize(){ renderer.setSize(innerWidth,innerHeight); composer.setSize(innerWidth,innerHeight);
  camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix(); bloom.resolution.set(innerWidth,innerHeight);
  pixelPass.uniforms.resolution.value.set(innerWidth,innerHeight);
  if(siteScreen.classList.contains('on')){ camera.updateMatrixWorld(); placeSiteScreen(); } }
addEventListener('resize', resize);
function animate(ts){
  clock+=0.016;
  let baseX=mx*0.8, baseY=0.7-my*0.45, baseZ=9.4, lookY=0.25, lookZ=0, sway=1, camHard=false;
  if(transition && (transition.which==='screen'||transition.which==='screenOut')){
    // zoom+boot combo IN (1.5s) / step back OUT (0.9s) — time-based so pace matches on 60/120Hz
    const out = transition.which==='screenOut';
    transition.t=Math.min(1,(performance.now()-transition.t0)/(out?900:1500));
    let e=transition.t*transition.t*(3-2*transition.t); if(out) e=1-e;
    baseZ=9.4-(9.4-6.0)*e; baseX*=(1-e); baseY=(0.7-my*0.45)*(1-e)+0.44*e;   // z 6.0 → the screen reads larger
    lookY=0.25+(0.44-0.25)*e; lookZ=1.31*e; sway=1-e; camHard=true;   // camera driven exactly → the iframe rect lands pixel-true
    if(!out){
      bootP=e;                                                        // the bar fills WITH the zoom — done when fully zoomed
      const seg=Math.floor(e*24); if(seg>_bootSeg){ _bootSeg=seg; playKey(true); }   // soft tick per bar segment
      if(transition.t>=1 && !transition.shown){ transition.shown=true; state='done'; _revealNow=true; }
    } else if(transition.t>=1){ transition=null; state='ready'; showReadyHint(); }
  }
  if(transition && transition.which==='world'){ transition.t=Math.min(1,transition.t+0.01); const e=transition.t*transition.t*(3-2*transition.t); baseZ=9.4-(9.4-4.8)*e; }
  baseX+=Math.sin(clock*0.25)*0.06*sway; baseY+=Math.cos(clock*0.2)*0.03*sway;
  if(camHard){ camera.position.set(baseX,baseY,baseZ); }
  else { camera.position.x+=(baseX-camera.position.x)*0.06; camera.position.y+=(baseY-camera.position.y)*0.06; camera.position.z+=(baseZ-camera.position.z)*0.06; }
  camera.lookAt(0,lookY,lookZ);
  if(_revealNow){ _revealNow=false; camera.updateMatrixWorld(); showSiteScreen(); }
  updateGodrays(); godrays.uniforms.uTime.value=clock;
  // hover focus lerp
  for(const k in tgt) cur[k]+=(tgt[k]-cur[k])*0.1;
  screenGlowMat.opacity=cur.sGlow; worldBlurMat.opacity=cur.wBlur; winFrameMat.emissiveIntensity=cur.wRim*0.9;
  worldSharpMat.color.setRGB(cur.wBright,cur.wBright,cur.wBright); worldBlurMat.color.setRGB(cur.wBright*0.95,cur.wBright*0.92,cur.wBright);
  screenMat.color.setRGB(cur.sDim,cur.sDim,cur.sDim);
  drawScreen(); vgPass.uniforms.time.value=clock;
  composer.render();
  if(!window.__rendered){ window.__rendered=true; renderer.shadowMap.autoUpdate=false;   // freeze the 2048² shadow pass after the first frame (nothing that casts shadows ever moves between refreshTime ticks)
    console.log('[crt3d] first frame, webgl2=', renderer.capabilities.isWebGL2); }
  requestAnimationFrame(animate);
}
/* fine film grain overlay (unseen-style), generated once */
{ const gc=document.createElement('canvas'); gc.width=gc.height=160; const gx=gc.getContext('2d');
  const id=gx.createImageData(160,160), gd=id.data;
  for(let i=0;i<gd.length;i+=4){ const v=Math.random()*255; gd[i]=gd[i+1]=gd[i+2]=v; gd[i+3]=255; }
  gx.putImageData(id,0,0);
  document.getElementById('grain').style.backgroundImage=`url(${gc.toDataURL()})`; }
(async()=>{ try{ await document.fonts.ready; }catch(e){} resize(); requestAnimationFrame(animate); })();
</script>
</body>
</html>
