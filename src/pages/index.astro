function makeBeamTex(){
  const W=160,H=512,cv=document.createElement('canvas'); cv.width=W; cv.height=H; const c=cv.getContext('2d');
  const img=c.createImageData(W,H), d=img.data;
  const G=64, seed=new Float32Array(G*G); for(let i=0;i<seed.length;i++) seed[i]=Math.random();
  const sm=t=>t*t*(3-2*t), gx=v=>((v%G)+G)%G;
  const vn=(x,y)=>{ const xi=Math.floor(x),yi=Math.floor(y),xf=x-xi,yf=y-yi;
    const a=seed[gx(yi)*G+gx(xi)],b=seed[gx(yi)*G+gx(xi+1)],e=seed[gx(yi+1)*G+gx(xi)],f=seed[gx(yi+1)*G+gx(xi+1)];
    const u=sm(xf),v=sm(yf); return (a*(1-u)+b*u)*(1-v)+(e*(1-u)+f*u)*v; };
  const fbm=(x,y)=>{ let s=0,amp=0.5,fr=1; for(let o=0;o<4;o++){ s+=vn(x*fr,y*fr)*amp; fr*=2; amp*=0.5; } return s; };
  for(let y=0;y<H;y++)for(let x=0;x<W;x++){ const i=(y*W+x)*4;
    const vf=Math.pow(Math.max(0,1-y/H),1.4);                  // soft vertical fade
    const hx=(x/W)*2-1; const env=Math.exp(-hx*hx*1.05);       // very soft horizontal envelope
    const n=fbm(x*0.07, y*0.014);                              // vertically-streaky dust noise
    let a=env*vf*(0.4+0.85*n); a=a<0?0:a>1?1:a;
    d[i]=255; d[i+1]=255; d[i+2]=255; d[i+3]=Math.round(a*255); }
  c.putImageData(img,0,0);
  const t=new THREE.CanvasTexture(cv); t.colorSpace=THREE.SRGBColorSpace;
  t.minFilter=THREE.LinearMipmapLinearFilter; t.generateMipmaps=true; return t;
}
